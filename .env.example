# Picasso Dev Skill 环境配置示例
# 使用方式：
# 1. 复制本文件为 .env
# 2. 只修改你本机真实存在的路径
# 3. 不需要的端或平台技能目录可以留空

# -----------------------------------------------------------------------------
# 运行目录
# -----------------------------------------------------------------------------
# PICASSO_ENV_BOUNDARY_MODE
# 作用：强制 skill 只在本地边界内工作
# 固定：local-only
PICASSO_ENV_BOUNDARY_MODE=local-only

# PICASSO_ALLOWED_RUNTIME_PROFILES
# 作用：允许视为“本地环境”的 Spring profile 集合
# 固定：local,dev
PICASSO_ALLOWED_RUNTIME_PROFILES=local,dev

# PICASSO_FORBIDDEN_RUNTIME_PROFILES
# 作用：明确禁止尝试连接、查询、部署的 profile 集合
# 固定：test,uat,prod
PICASSO_FORBIDDEN_RUNTIME_PROFILES=test,uat,prod

# PICASSO_WORKSPACE_DIR
# 作用：需求运行产物目录，对应仓库内 workspace/
# 应填：当前 skill 仓库里的运行目录，建议使用相对路径 ./workspace
PICASSO_WORKSPACE_DIR=./workspace

# PICASSO_SERVER_TASK_DIR
# 作用：服务端任务协同目录，对应 workspace/server-tasks/
# 应填：当前 skill 仓库里的服务端任务目录，建议使用相对路径 ./workspace/server-tasks
PICASSO_SERVER_TASK_DIR=./workspace/server-tasks

# PICASSO_DEFAULT_BRANCH
# 作用：默认基线分支名
# 应填：你们项目常用的主分支，例如 master / main / develop
PICASSO_DEFAULT_BRANCH=master

# -----------------------------------------------------------------------------
# 毕加索源码目录
# -----------------------------------------------------------------------------
# PICASSO_SERVER_CODE_DIR
# 作用：后端源码仓库地址
# 应填：picasso-server 本机绝对路径
PICASSO_SERVER_CODE_DIR=/path/to/picasso-server

# PICASSO_FRONT_CODE_DIR
# 作用：PC 前端源码仓库地址
# 应填：picasso-front 本机绝对路径
PICASSO_FRONT_CODE_DIR=/path/to/picasso-front

# PICASSO_MINIAPP_CODE_DIR
# 作用：微信小程序源码仓库地址
# 应填：picasso-mini-front 本机绝对路径；当前不做小程序可留空
PICASSO_MINIAPP_CODE_DIR=

# PICASSO_MOBILE_APP_CODE_DIR
# 作用：移动端 App 源码仓库地址
# 应填：Flutter App 或移动端仓库本机绝对路径；当前不做移动端可留空
PICASSO_MOBILE_APP_CODE_DIR=

# -----------------------------------------------------------------------------
# 本地运行编排
# -----------------------------------------------------------------------------
# PICASSO_AUTO_START_LOCAL_SERVICES
# 作用：进入本地联调 / 冒烟 / 发布准备时，是否自动拉起后端和前端
# 建议：true
PICASSO_AUTO_START_LOCAL_SERVICES=true

# PICASSO_AUTO_STOP_LOCAL_SERVICES
# 作用：冒烟脚本结束后，是否自动停止由脚本拉起的本地服务
# 建议：true
PICASSO_AUTO_STOP_LOCAL_SERVICES=true

# PICASSO_AUTO_FETCH_ACCESS_TOKEN
# 作用：是否在冒烟前自动调用登录接口获取 access token
# 建议：true；如果当前需求不依赖登录，也可以设为 false
PICASSO_AUTO_FETCH_ACCESS_TOKEN=true

# PICASSO_RUNTIME_READY_TIMEOUT_SEC
# 作用：后端 / 前端启动后的最长等待时间（秒）
# 建议：180
PICASSO_RUNTIME_READY_TIMEOUT_SEC=180

# PICASSO_RUNTIME_DIR
# 作用：运行时日志、PID、联调临时文件目录
# 应填：建议使用 skill 仓库内相对路径 ./workspace/tmp/runtime
PICASSO_RUNTIME_DIR=./workspace/tmp/runtime

# PICASSO_BACKEND_START_WORKDIR
# 作用：后端启动命令执行目录
# 建议：如果后端 Maven 根目录在 <PICASSO_SERVER_CODE_DIR>/picasso-server，则填写该目录
PICASSO_BACKEND_START_WORKDIR=/path/to/picasso-server/picasso-server

# PICASSO_BACKEND_START_CMD
# 作用：后端本地启动命令
# 建议：mvn spring-boot:run -Dspring-boot.run.profiles=local
PICASSO_BACKEND_START_CMD="mvn spring-boot:run -Dspring-boot.run.profiles=local"

# PICASSO_BACKEND_BASE_URL
# 作用：后端基础访问地址，供冒烟脚本拼接接口
# 建议：例如 http://127.0.0.1:8090
PICASSO_BACKEND_BASE_URL=http://127.0.0.1:8090

# PICASSO_BACKEND_HEALTH_URL
# 作用：后端健康检查地址；自动等待后端启动成功时使用
# 建议：例如 http://127.0.0.1:8090/actuator/health
PICASSO_BACKEND_HEALTH_URL=http://127.0.0.1:8090/actuator/health

# PICASSO_BACKEND_EXPECT_TEXT
# 作用：后端健康检查成功时的期望关键字；留空则只要求 HTTP 可访问
PICASSO_BACKEND_EXPECT_TEXT=UP

# PICASSO_FRONTEND_START_WORKDIR
# 作用：前端启动命令执行目录
# 建议：如果 PC 前端运行在 apps/web-antd，则填写该目录
PICASSO_FRONTEND_START_WORKDIR=/path/to/picasso-front/apps/web-antd

# PICASSO_FRONTEND_START_CMD
# 作用：前端本地启动命令
# 建议：pnpm dev
PICASSO_FRONTEND_START_CMD="pnpm dev"

# PICASSO_FRONTEND_READY_URL
# 作用：前端就绪检查地址；自动等待页面可访问时使用
# 建议：例如 http://127.0.0.1:8011
PICASSO_FRONTEND_READY_URL=http://127.0.0.1:8011

# PICASSO_FRONTEND_EXPECT_TEXT
# 作用：前端页面加载成功时的期望关键字；留空则只要求 HTTP 可访问
PICASSO_FRONTEND_EXPECT_TEXT=

# PICASSO_API_PREFIX
# 作用：接口前缀，冒烟脚本中的核心 CRUD 接口默认基于它拼接
# 建议：Picasso 前端通常为 /admin-api
PICASSO_API_PREFIX=/admin-api

# PICASSO_LOGIN_URL
# 作用：登录接口地址；自动获取 Token 时使用
# 建议：例如 http://127.0.0.1:8090/admin-api/system/auth/login
PICASSO_LOGIN_URL=http://127.0.0.1:8090/admin-api/system/auth/login

# PICASSO_LOGIN_METHOD
# 作用：登录接口 HTTP Method
# 建议：POST
PICASSO_LOGIN_METHOD=POST

# PICASSO_LOGIN_USERNAME
# 作用：本地联调登录用户名
PICASSO_LOGIN_USERNAME=

# PICASSO_LOGIN_PASSWORD
# 作用：本地联调登录密码
PICASSO_LOGIN_PASSWORD=

# PICASSO_LOGIN_TENANT_ID
# 作用：租户 ID；多租户系统自动登录和冒烟时会作为默认 Tenant-Id 头
PICASSO_LOGIN_TENANT_ID=1

# PICASSO_LOGIN_TENANT_HEADER
# 作用：租户请求头名称
# 建议：Tenant-Id
PICASSO_LOGIN_TENANT_HEADER=Tenant-Id

# PICASSO_LOGIN_REQUEST_BODY_TEMPLATE
# 作用：自动登录时的请求体模板，支持 {{username}} / {{password}} / {{tenant_id}}
# 建议：{"username":"{{username}}","password":"{{password}}","tenantId":"{{tenant_id}}"}
PICASSO_LOGIN_REQUEST_BODY_TEMPLATE='{"username":"{{username}}","password":"{{password}}","tenantId":"{{tenant_id}}"}'

# PICASSO_LOGIN_TOKEN_PATH
# 作用：从登录响应 JSON 中提取 token 的路径
# 建议：data.accessToken 或 accessToken
PICASSO_LOGIN_TOKEN_PATH=data.accessToken

# -----------------------------------------------------------------------------
# 本地数据库连接
# -----------------------------------------------------------------------------
# 作用：本地联调、SQL 校验、数据检查时使用
# 应填：你本机本地数据库连接信息
PICASSO_LOCAL_DB_HOST=127.0.0.1
PICASSO_LOCAL_DB_PORT=5432
PICASSO_LOCAL_DB_NAME=ruoyi-vue-pro
PICASSO_LOCAL_DB_USER=postgres
PICASSO_LOCAL_DB_PASSWORD=postgres

# PICASSO_REQUIRE_LOCAL_DB_CLI
# 作用：进入 SQL / 数据查询阶段时，是否强制要求安装 psql
# 建议：true
PICASSO_REQUIRE_LOCAL_DB_CLI=true

# -----------------------------------------------------------------------------
# CLI 命令入口
# -----------------------------------------------------------------------------
# CLAUDE_BIN
# 作用：Claude CLI 命令名
# CODEX_BIN
# 作用：Codex CLI 命令名
# CODEX_PLUGIN_CC_ENABLED
# 作用：是否启用 Claude + Codex 协作增强模式
CLAUDE_BIN=claude
CODEX_BIN=codex
CODEX_PLUGIN_CC_ENABLED=false

# -----------------------------------------------------------------------------
# 技能安装目录
# -----------------------------------------------------------------------------
# OPENCLAW_SKILLS_DIR
# 作用：OpenClaw 技能目录；如果你不用 OpenClaw 可以留空
# 应填：例如 /Users/你的用户名/.openclaw/skills
OPENCLAW_SKILLS_DIR=

# CLAUDE_SKILLS_DIR
# 作用：Claude 技能目录；如果你不用本地 Claude skills 目录可以留空
# 应填：例如 /Users/你的用户名/.claude/skills
CLAUDE_SKILLS_DIR=

# CODEX_SKILLS_DIR
# 作用：Codex 技能目录；如果你不用本地 Codex skills 目录可以留空
# 应填：例如 /Users/你的用户名/.codex/skills
CODEX_SKILLS_DIR=

# OPENCODE_SKILLS_DIR
# 作用：OpenCode 技能目录；如果你不用 OpenCode skills 目录可以留空
# 应填：按你的 OpenCode 本地技能目录填写
OPENCODE_SKILLS_DIR=
